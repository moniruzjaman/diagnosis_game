# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Force LF for config files
.gitattributes text eol=lf
.gitignore text eol=lf
.env.example text eol=lf
